# Supabase project URL and anon (public) key — Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SERVER ONLY. Never expose to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Base URL of the deployed app (used for auth redirect links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
