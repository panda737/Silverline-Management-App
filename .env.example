# Supabase project URL and anon (public) key — Settings → API in the Supabase dashboard
# NEXT_PUBLIC_* lines are kept for scripts/ (seed, rls-smoke-test); the app itself
# reads the VITE_ ones.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Service role key — scripts + Supabase edge function secrets ONLY. Never expose
# to the browser or commit it. The app bundle must never reference it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Base URL of the deployed app (used by scripts and the invite edge function).
# Production is https://silverline-management.co.za (www redirects to the apex).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
